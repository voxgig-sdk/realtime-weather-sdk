  "components": {
    "schemas": {
      "CollectionMetadata": {
        "type": "object",
        "properties": {
          "collectionId": {
            "type": "integer",
            "description": "Unique identifier for the collection",
            "example": 1459
          },
          "title": {
            "type": "string",
            "description": "Title of the collection",
            "example": "Realtime Weather Readings across Singapore"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the collection"
          },
          "agency": {
            "type": "string",
            "description": "Publishing agency",
            "example": "National Environment Agency (NEA)"
          },
          "datasets": {
            "type": "array",
            "description": "List of datasets in the collection",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "Dataset": {
        "type": "object",
        "properties": {
          "datasetId": {
            "type": "string",
            "description": "Unique identifier for the dataset"
          },
          "name": {
            "type": "string",
            "description": "Name of the dataset"
          },
          "coverage": {
            "type": "string",
            "description": "Time coverage of the dataset",
            "example": "May 2016 to Feb 2026"
          },
          "type": {
            "type": "string",
            "description": "Type of dataset",
            "enum": [
              "API",
              "file"
            ]
          }
        }
      },
      "WeatherData": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "stations": {
                "type": "array",
                "description": "Weather stations providing data",
                "items": {
                  "$ref": "#/components/schemas/Station"
                }
              },
              "readingType": {
                "type": "string",
                "description": "Type of weather reading",
                "example": "temperature"
              },
              "readingUnit": {
                "type": "string",
                "description": "Unit of measurement",
                "example": "deg C"
              }
            }
          },
          "data": {
            "type": "array",
            "description": "Array of weather readings",
            "items": {
              "$ref": "#/components/schemas/Reading"
            }
          }
        }
      },
      "Station": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique station identifier"
          },
          "deviceId": {
            "type": "string",
            "description": "Device identifier"
          },
          "name": {
            "type": "string",
            "description": "Station name"
          },
          "location": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number",
                "format": "double",
                "description": "Latitude coordinate"
              },
              "longitude": {
                "type": "number",
                "format": "double",
                "description": "Longitude coordinate"
              }
            }
          }
        }
      },
      "Reading": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the reading"
          },
          "stationId": {
            "type": "string",
            "description": "Station identifier"
          },
          "value": {
            "type": "number",
            "format": "double",
            "description": "The measured value"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "details": {
            "type": "object",
            "description": "Additional error details"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Collections",
      "description": "Operations related to collection metadata"
    },
    {
      "name": "Weather Data",
      "description": "Operations for retrieving real-time weather readings"
    }
  ],
  "externalDocs": {
    "description": "API Documentation",
    "url": "https://data.gov.sg/collections/1459/view"
  }
}
