{
  "openapi": "3.0.3",
  "info": {
    "title": "Realtime Weather API",
    "description": "This API provides real-time readings of temperature, humidity, precipitation, and wind conditions across various weather stations in Singapore at intervals of up to one minute. Managed by the National Environment Agency (NEA), it allows users to access detailed weather data for public use.",
    "version": "2.0.0",
    "contact": {
      "name": "National Environment Agency (NEA)",
      "url": "https://data.gov.sg"
    },
    "license": {
      "name": "Open Data Licence",
      "url": "https://data.gov.sg"
    }
  },
  "servers": [
    {
      "url": "https://api-production.data.gov.sg/v2/public/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/collections/{collectionId}/metadata": {
      "get": {
        "summary": "Get collection metadata",
        "description": "Retrieves the metadata for a specific weather data collection. Collection ID 1459 corresponds to Realtime Weather Readings across Singapore.",
        "operationId": "getCollectionMetadata",
        "tags": [
          "Collections"
        ],
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "description": "The unique identifier for the collection. Use 1459 for Realtime Weather Readings.",
            "schema": {
              "type": "integer",
              "example": 1459
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with collection metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionMetadata"
                }
              }
            }
          },
          "404": {
            "description": "Collection not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/collections/{collectionId}/air-temperature": {
      "get": {
        "summary": "Get air temperature readings",
        "description": "Retrieves real-time air temperature readings across weather stations in Singapore. Coverage from May 2016 to February 2026.",
        "operationId": "getAirTemperature",
        "tags": [
          "Weather Data"
        ],
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "description": "The collection identifier (1459 for Realtime Weather)",
            "schema": {
              "type": "integer",
              "example": 1459
            }
          },
          {
            "name": "date",
            "in": "query",
            "required": false,
            "description": "Filter by date in ISO 8601 format (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "datetime",
            "in": "query",
            "required": false,
            "description": "Filter by datetime in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with air temperature data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherData"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Data not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
